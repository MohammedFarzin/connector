<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_assistant_connector_settings" model="ir.ui.view">
        <field name="name">CRM Assistant Connector Settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="CRM Assistant Connector" string="CRM Assistant Connector"
                     name="crm_assistant_connector" groups="base.group_system">
                    <block title="Gateway Configuration" name="crm_assistant_connector_gateway">
                        <setting help="URL of the CRM Assistant Gateway service">
                            <field name="crm_assistant_gateway_url"
                                   placeholder="http://localhost:8000"/>
                        </setting>
                        <setting help="Shared secret for HMAC request signing">
                            <field name="crm_assistant_secret" password="True"
                                   placeholder="Paste from your CRM Assistant dashboard"/>
                        </setting>
                    </block>
                    <block title="Connection Test" name="crm_assistant_connector_test">
                        <setting>
                            <button name="test_crm_assistant_connection"
                                    type="object" string="Test Connection"
                                    class="btn btn-primary"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
