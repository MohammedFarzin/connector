<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_assistant_connector_settings" model="ir.ui.view">
        <field name="name">CRM Assistant Connector Settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="CRM Assistant Connector"
                     string="CRM Assistant Connector" data-key="crm_assistant_connector">
                    <h2>CRM Assistant Connector</h2>
                    <div class="row mt16">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="crm_assistant_gateway_url" string="Gateway URL"/>
                                <field name="crm_assistant_gateway_url"
                                       placeholder="https://api.your-gateway.com"
                                       class="oe_inline"/>
                            </div>
                        </div>
                    </div>
                    <div class="row mt16">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="crm_assistant_secret" string="Shared Secret"/>
                                <field name="crm_assistant_secret"
                                       password="True"
                                       placeholder="Paste from your CRM Assistant dashboard"
                                       class="oe_inline"/>
                                <div class="text-muted">
                                    Provisioned by your CRM Assistant admin. Used for HMAC signing.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt16">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <button name="test_crm_assistant_connection"
                                        type="object" string="Test Connection"
                                        class="btn btn-primary"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
