<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="crm_assistant.ChatInput" owl="1">
        <div class="chat-input">
            <textarea
                class="chat-input__textarea"
                placeholder="Ask about your CRM..."
                t-model="state.text"
                t-on-keydown="onKeydown"
                t-att-disabled="props.loading or props.disabled"
                rows="1"
            />

            <button
                class="chat-input__send-btn"
                t-on-click="send"
                t-att-disabled="!state.text.trim() or props.loading or props.disabled"
                title="Send message"
            >
                <i class="fa fa-send"/>
            </button>
        </div>
    </t>

</templates>
